{
	"compilerOptions": {
		"target": "esnext",
		"lib": ["es2023"],
		"moduleDetection": "force",
		"module": "preserve",
		"moduleResolution": "bundler",
		"paths": {
			"@/*": ["./src/*"]
		},
		"resolveJsonModule": true,
		"types": [],
		"strict": true,
		"noUnusedLocals": true,
		"declaration": true,
		"emitDeclarationOnly": true,
		"esModuleInterop": true,
		"isolatedModules": true,
		"verbatimModuleSyntax": true,
		"skipLibCheck": true,
		"isolatedDeclarations": true
	},
	"include": ["src"]
}
