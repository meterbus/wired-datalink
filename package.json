{
	"name": "@meterbus/wired-datalink",
	"type": "module",
	"version": "1.0.0",
	"description": "Wired M-Bus datalink primitives and codecs",
	"author": "Nicolas Hedger <nicolas@hedger.ch>",
	"license": "MIT",
	"homepage": "https://github.com/meterbus/wired-datalink#readme",
	"repository": {
		"type": "git",
		"url": "git+https://github.com/meterbus/wired-datalink.git"
	},
	"bugs": {
		"url": "https://github.com/meterbus/wired-datalink/issues"
	},
	"exports": {
		".": "./dist/index.mjs",
		"./package.json": "./package.json"
	},
	"files": [
		"dist"
	],
	"publishConfig": {
		"access": "public",
		"provenance": true
	},
	"scripts": {
		"build": "tsdown",
		"dev": "tsdown --watch",
		"test": "vitest",
		"test:coverage": "vitest --run --coverage",
		"typecheck": "tsc --noEmit",
		"prepublishOnly": "pnpm typecheck && pnpm build"
	},
	"packageManager": "pnpm@11.11.0",
	"devDependencies": {
		"@biomejs/biome": "^2.5.3",
		"@typescript/native-preview": "7.0.0-dev.20260509.2",
		"@vitest/coverage-v8": "^4.1.10",
		"git-cliff": "^2.13.1",
		"lefthook": "2.1.10",
		"tsdown": "^0.22.0",
		"typescript": "^6.0.3",
		"vitest": "^4.1.5"
	}
}
